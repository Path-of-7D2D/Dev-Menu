<?xml version="1.0" encoding="UTF-8" ?>
<configs>

	<append xpath="/templates">
		<dev_menu_item_category_entry width="220" height="34">
			<rect name="entry" width="${width}" height="${height}" controller="DevMenu.DevMenuItemCategoryList+EntryController, DevMenu" style="press, hover, scroll" sound_play_on_hover="[default_hover]">
				<sprite depth="1" name="rowBackground" sprite="menu_empty3px" pos="0,0" width="${width}" height="${height}" color="[black]" type="sliced" fillcenter="true" globalopacitymod="0.68" visible="{hasentry}" />
				<sprite depth="2" name="selection" sprite="menu_empty3px" pos="0,0" width="${width}" height="${height}" color="[mediumGrey]" type="sliced" fillcenter="true" globalopacitymod="0.65" visible="{hovered}" />
				<sprite depth="3" name="selected" sprite="menu_empty3px" pos="0,0" width="${width}" height="${height}" color="[white]" type="sliced" fillcenter="true" globalopacitymod="0.28" visible="{isselected}" />
				<label depth="4" name="name" pos="8,-7" width="150" height="24" text="{name}" font_size="24" justify="left" pivot="top_left" />
				<label depth="4" name="count" pos="162,-8" width="50" height="24" text="{count}" font_size="22" justify="right" pivot="top_left" color="[white]" />
			</rect>
		</dev_menu_item_category_entry>

		<dev_menu_item_entry width="1080" height="34">
			<rect name="entry" width="${width}" height="${height}" controller="DevMenu.DevMenuItemList+EntryController, DevMenu" style="press, hover, scroll" on_doubleclick="true" sound_play_on_hover="[default_hover]">
				<sprite depth="1" name="rowBackground" sprite="menu_empty3px" pos="0,0" width="${width}" height="${height}" color="[black]" type="sliced" fillcenter="true" globalopacitymod="0.68" visible="{hasentry}" />
				<sprite depth="2" name="selection" sprite="menu_empty3px" pos="0,0" width="${width}" height="${height}" color="[mediumGrey]" type="sliced" fillcenter="true" globalopacitymod="0.65" visible="{hovered}" />
				<sprite depth="3" name="selected" sprite="menu_empty3px" pos="0,0" width="${width}" height="${height}" color="[white]" type="sliced" fillcenter="true" globalopacitymod="0.28" visible="{isselected}" />
				<label depth="4" name="category" pos="8,-8" width="110" height="24" text="{category}" font_size="22" justify="left" pivot="top_left" color="[white]" />
				<label depth="4" name="name" pos="130,-7" width="245" height="24" text="{name}" font_size="24" justify="left" pivot="top_left" />
				<label depth="4" name="itemName" pos="390,-8" width="245" height="24" text="{itemname}" font_size="22" justify="left" pivot="top_left" color="[white]" />
				<label depth="4" name="tiered" pos="650,-8" width="50" height="24" text="{tiered}" font_size="22" justify="left" pivot="top_left" color="[white]" />
				<label depth="4" name="tags" pos="712,-8" width="${width-720}" height="24" text="{tags}" font_size="20" justify="left" pivot="top_left" color="[lightGrey]" />
			</rect>
		</dev_menu_item_entry>

		<dev_menu_cheat_entry width="1080" height="42">
			<rect name="entry" width="${width}" height="${height}" controller="DevMenu.DevMenuCheatList+EntryController, DevMenu" style="press, hover, scroll" on_doubleclick="true" sound_play_on_hover="[default_hover]">
				<sprite depth="1" name="rowBackground" sprite="menu_empty3px" pos="0,0" width="${width}" height="${height}" color="[black]" type="sliced" fillcenter="true" globalopacitymod="0.68" visible="{hasentry}" />
				<sprite depth="2" name="selection" sprite="menu_empty3px" pos="0,0" width="${width}" height="${height}" color="[mediumGrey]" type="sliced" fillcenter="true" globalopacitymod="0.65" visible="{hovered}" />
				<sprite depth="3" name="selected" sprite="menu_empty3px" pos="0,0" width="${width}" height="${height}" color="[white]" type="sliced" fillcenter="true" globalopacitymod="0.28" visible="{isselected}" />
				<label depth="4" name="name" pos="8,-8" width="250" height="26" text="{name}" font_size="26" justify="left" pivot="top_left" />
				<label depth="4" name="description" pos="280,-9" width="560" height="24" text="{description}" font_size="22" justify="left" pivot="top_left" color="[white]" />
				<label depth="4" name="status" pos="860,-9" width="210" height="24" text="{status}" font_size="22" justify="right" pivot="top_left" color="[white]" />
			</rect>
		</dev_menu_cheat_entry>

		<dev_menu_tile_entity_entry width="1080" height="34">
			<rect name="entry" width="${width}" height="${height}" controller="DevMenu.LootableTileEntityList+EntryController, DevMenu" style="press, hover, scroll" on_doubleclick="true" sound_play_on_hover="[default_hover]">
				<sprite depth="1" name="rowBackground" sprite="menu_empty3px" pos="0,0" width="${width}" height="${height}" color="[black]" type="sliced" fillcenter="true" globalopacitymod="0.68" visible="{hasentry}" />
				<sprite depth="2" name="selection" sprite="menu_empty3px" pos="0,0" width="${width}" height="${height}" color="[mediumGrey]" type="sliced" fillcenter="true" globalopacitymod="0.65" visible="{hovered}" />
				<sprite depth="3" name="selected" sprite="menu_empty3px" pos="0,0" width="${width}" height="${height}" color="[white]" type="sliced" fillcenter="true" globalopacitymod="0.28" visible="{isselected}" />
				<label depth="4" name="name" pos="8,-7" width="350" height="24" text="{name}" font_size="24" justify="left" pivot="top_left" />
				<label depth="4" name="blockName" pos="370,-8" width="350" height="24" text="{blockname}" font_size="22" justify="left" pivot="top_left" color="[white]" />
				<label depth="4" name="lootList" pos="732,-8" width="230" height="24" text="{lootlist}" font_size="22" justify="left" pivot="top_left" color="[white]" />
				<label depth="4" name="flags" pos="974,-8" width="98" height="24" text="{flags}" font_size="20" justify="left" pivot="top_left" color="[lightGrey]" />
			</rect>
		</dev_menu_tile_entity_entry>
	</append>

</configs>
